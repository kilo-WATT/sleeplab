# =============================================================================
# SleepLab — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values.
# Used by compose.advanced.yaml (compose.yaml has its own defaults).
#
#   cp .env.example .env
#   docker compose -f compose.advanced.yaml up -d
#
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Generate with: openssl rand -hex 32
SECRET_KEY=

# Database password — pick a strong random value.
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# Database (optional — defaults work for most setups)
# -----------------------------------------------------------------------------

POSTGRES_DB=cpap
POSTGRES_USER=cpap

# -----------------------------------------------------------------------------
# API / Networking
# -----------------------------------------------------------------------------

# Public URL for frontend config.js.  Set to your domain or IP if accessing
# from another device (e.g. http://192.168.1.50:8080).
API_URL=http://localhost:8000

# Comma-separated CORS origins.  * allows any origin (dev only).
CORS_ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Compliance Thresholds (defaults shown — adjust to your insurer or clinician)
# -----------------------------------------------------------------------------

# Minimum hours of use for a night to count as compliant.
ADHERENCE_THRESHOLD_HOURS=4.0
# Optional lower bound for three-tier coloring (red/orange/green).  Leave empty to disable.
ADHERENCE_BORDERLINE_HOURS=
# Target compliance percentage for pass/fail.
ADHERENCE_TARGET_PCT=70.0
# Number of consecutive days in a single compliance window.
ADHERENCE_WINDOW_DAYS=30
# Overall evaluation period (days) for sliding-window search.
ADHERENCE_EVALUATION_DAYS=90
# Window evaluation logic: "best_consecutive" (sliding) or "last_consecutive" (most recent only).
ADHERENCE_WINDOW_LOGIC=best_consecutive
# Lookback days for ongoing maintenance monitoring.
ADHERENCE_LOOKBACK_DAYS=90

# -----------------------------------------------------------------------------
# Optional Features
# -----------------------------------------------------------------------------

# Set to "true" to disable new user registration.
DISABLE_USER_REGISTRATION=false

# OpenAI API key for AI-powered session summaries.  Leave empty to disable.
OPENAI_API_KEY=

# Set to "true" to enable SleepHQ cloud import.
SLEEPHQ_ENABLED=false
# Required when SLEEPHQ_ENABLED=true:
# SLEEPHQ_CLIENT_ID=
# SLEEPHQ_CLIENT_SECRET=
# Optional; auto-resolved if omitted:
# SLEEPHQ_TEAM_ID=

# Shared secret for CPAP import webhooks.  Generate with: openssl rand -hex 16
IMPORT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Wearable Data Integration
# -----------------------------------------------------------------------------

WEARABLE_ENABLED=true
# Provider: "open-wearables" or "mirobody"
WEARABLE_DEFAULT_PROVIDER=
WEARABLE_DEFAULT_BASE_URL=
WEARABLE_DEFAULT_API_KEY=

# -----------------------------------------------------------------------------
# Time Zones
# -----------------------------------------------------------------------------

# IANA timezone of the CPAP machine (e.g. America/New_York, Europe/London)
MACHINE_TZ=UTC
# IANA timezone for UI chart labels and session cards
DISPLAY_TZ=UTC

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------

# Host path to a CPAP DATALOG directory for local file import.
# Example: /mnt/nas/cpap-data/DATALOG
LOCAL_DATALOG_PATH=./data
