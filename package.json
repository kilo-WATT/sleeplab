{
  "name": "sleeplab",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "api": "nx serve api",
    "frontend": "nx serve frontend",
    "dev": "nx run-many --target=serve --projects=api,frontend --parallel",
    "build": "nx build frontend",
    "lint": "nx lint frontend",
    "test": "nx run-many --target=test --projects=api,frontend",
