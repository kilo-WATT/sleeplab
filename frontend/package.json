{
  "name": "frontend",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:storybook": "vitest run -c vitest.storybook.ts",
    "capture:yaml": "node ../scripts/capture-yaml.js",
    "capture:ci": "start-server-and-test preview http://127.0.0.1:4173 capture:yaml",
    "capture:stories": "node ../scripts/capture-stories.js",
    "capture:stories:ci": "start-server-and-test \"npx serve storybook-static -p 6006 --no-clipboard\" http://127.0.0.1:6006 capture:stories",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react": "^10.4.2",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "react-is": "^19.2.7",
    "start-server-and-test": "^3.0.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
