{
  "name": "api",
  "projectType": "application",
  "sourceRoot": "api",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "python3 -m compileall api importer"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest -v --tb=short"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3.12 -m uvicorn api.main:app --host 0.0.0.0 --port 8000"
      }
    }
  }
}
